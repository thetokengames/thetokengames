        n = int(x)
    except:
        return False
    
    if n < 10:
        return False
    
    s = str(n)
    num_digits = len(s)
    
    # Condition A: Armstrong/Narcissistic number
    # (sum of each digit raised to the power of number of digits equals n)
    power_sum = sum(int(d) ** num_digits for d in s)
    if power_sum != n:
        return False
    
    # Condition B: All digits are odd
    for d in s:
        if int(d) % 2 == 0:
            return False
    
    # Condition C: The digit sum itself is odd
