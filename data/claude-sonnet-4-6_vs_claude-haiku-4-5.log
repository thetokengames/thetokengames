def mystery(x):
    try:
        n = int(x)
    except:
        return False

    if n <= 1000:
        return False

    # Part A
    lo, hi = 0, n
    while lo < hi:
        mid = (lo + hi + 1) // 2
        if mid * mid <= n:
            lo = mid
        else:
            hi = mid - 1
    if lo * lo != n:
        return False

    # Part B
    p, q = lo, 0
    while p:
        q = (q << 1) | (p & 1)
        p >>= 1
    if q != lo:
        return False

    # Part C
    t, r = n, 0
    while t:
        r += t % 10
        t //= 10
    if n % r != 0:
        return False

    return True
```

