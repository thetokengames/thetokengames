def mystery(x):
    try:
        n = int(x)
    except:
        return False

    if n <= 1000:
        return False

    # Part A
    temp = n
    prime_factors = []
    d = 2
    while d * d <= temp:
        cnt = 0
        while temp % d == 0:
            cnt += 1
            temp //= d
        if cnt == 1:
            prime_factors.append(d)
        elif cnt > 1:
            return False
        d += 1
    if temp > 1:
        prime_factors.append(temp)
    if len(prime_factors) != 3:
        return False

    # Part B
    digits_b5 = []
    t = n
    while t > 0:
        digits_b5.append(t % 5)
        t //= 5
    if digits_b5 != digits_b5[::-1]:
        return False

    # Part C
    ds = sum(int(c) for c in str(n))
    if ds < 2:
        return False
    for i in range(2, int(ds ** 0.5) + 1):
        if ds % i == 0:
            return False

    return True
```

