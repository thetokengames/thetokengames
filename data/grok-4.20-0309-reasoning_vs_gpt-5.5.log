def mystery(x):
    if type(x) is not int:
        return False

    n = int(
        "114381625757888867669235779976146612010218296721242362562561842935"
        "706935245733897830597123563958705058989075147599290026879543541"
    )
    c = int(
        "968696137546220614771409222543558829057599911245743198746951209308"
        "16298225145708356931476622883989628013391990551829945157815154"
    )

    if not (10**77 < x < 10**78):
        return False

    s = str(x)
    if len(s) != 78:
        return False

    try:
        if any(not (0 <= int(s[i:i+2]) <= 26) for i in range(0, 78, 2)):
            return False
    except Exception:
        return False

    return pow(x, 9007, n) == c
