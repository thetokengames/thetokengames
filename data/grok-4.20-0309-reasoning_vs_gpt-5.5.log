import hashlib
import unicodedata

def mystery(x):
    if not isinstance(x, str):
        return False

    if len(x) != 56:
        return False

    if any(ord(ch) <= 0xFFFF for ch in x):
        return False

    try:
        y = unicodedata.normalize("NFKC", x)
        b = y.encode("ascii")
    except Exception:
        return False

    if len(b) != 56:
        return False

    if any(not (97 <= c <= 122) for c in b):
        return False

    return (
        hashlib.sha1(b).hexdigest() == "84983e441c3bd26ebaae4aa1f95129e5e54670f1"
        and hashlib.sha256(b).hexdigest() == "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1"
    )
```

