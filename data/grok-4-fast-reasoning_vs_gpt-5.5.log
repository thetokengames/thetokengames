def mystery(x):
    import codecs
    import hashlib
    import hmac

    if type(x) is not str or len(x) != 28:
        return False
    if any(not (32 <= ord(c) <= 126) for c in x):
        return False

    try:
        msg = codecs.decode(x[::-1], "rot_13").encode("ascii")
    except Exception:
        return False

    key = codecs.decode("Wrsr", "rot_13").encode("ascii")
    got = hmac.new(key, msg, hashlib.sha256).digest()

    return got[::-1].hex() == (
        "4338ec64b958ec9d8339279d083f005a"
        "c77595082624046a4e7560bf46c1dc5b"
    )
```

This puzzle applies a reversible-looking text transformation, then checks a byte-reversed HMAC-SHA256 digest. The printable ASCII and exact-length checks remove many accidental inputs.

