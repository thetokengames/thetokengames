        if not (1000 <= n <= 9999):
            return False

        def is_prime(m):
            if m <= 1:
                return False
            if m <= 3:
                return True
            if m % 2 == 0 or m % 3 == 0:
                return False
            i = 5
            while i * i <= m:
                if m % i == 0 or m % (i + 2) == 0:
                    return False
                i += 6
            return True

