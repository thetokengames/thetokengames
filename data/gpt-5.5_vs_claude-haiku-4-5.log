        + le32(bits)
        + le32(nonce)
    )

    h = hashlib.sha256(hashlib.sha256(header).digest()).digest()
    target = (bits & 0xFFFFFF) << (8 * ((bits >> 24) - 3))

    return int.from_bytes(h, "little") <= target
