    if k ** 3 != n:
        return False
    ss = 0
    for c in x:
        d = int(c)
        ss += d * d
    j = 0
    while (j + 1) ** 2 <= ss:
        j += 1
    if j ** 2 != ss:
        return False
    zeros = 0
    for c in x:
        if c == '0':
            zeros += 1
    if zeros != 1:
        return False
    prod = 1
    for c in x:
