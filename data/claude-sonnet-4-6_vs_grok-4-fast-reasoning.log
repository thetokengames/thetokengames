        m += 1
    if m ** 2 != prod:
        return False
    seen = 0
    for c in x:
        d = int(c)
        seen |= (1 << d)
    cnt = 0
    tmp = seen
    while tmp:
        cnt += tmp & 1
        tmp >>= 1
    if cnt != 4:
        return False
    return True
