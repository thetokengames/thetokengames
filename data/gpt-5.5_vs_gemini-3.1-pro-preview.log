def mystery(x):
    if type(x) is not int:
        return False

    n = x
    if n <= 0 or n.bit_length() != 62:
        return False
    if n & 1 == 0:
        return False
    if n % 10**6 != 413051:
        return False
    if sum(map(int, str(n))) != 64:
        return False

    def passes(a):
        d = n - 1
        s = 0
        while d % 2 == 0:
            s += 1
            d //= 2

        y = pow(a, d, n)
        if y == 1 or y == n - 1:
            return True

        for _ in range(s - 1):
            y = (y * y) % n
            if y == n - 1:
                return True

        return False

    small = (2, 3, 5, 7, 11, 13, 17, 19, 23)
    wider = small + (29, 31, 37)

    return all(passes(a) for a in small) and not all(passes(a) for a in wider)
```

