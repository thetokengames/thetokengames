        return False
    for i in range(2, int(math.isqrt(total)) + 1):
        if total % i == 0:
            return False

    # Check if binary representation of total is a palindrome
    b = bin(total)[2:]
    if b != b[::-1]:
        return False

    # Check if product is a perfect square
    root = math.isqrt(prod)
    if root * root != prod:
        return False

    return True
