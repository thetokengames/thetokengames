    # x must be a positive integer
    if not isinstance(x, int) or x <= 0:
        return False
    
    # x must have exactly 6 digits
    if x < 100000 or x > 999999:
        return False
    
    s = str(x)
    
    # x must be a palindrome
    if s != s[::-1]:
        return False
    
    # x must be a perfect square
    root = int(math.isqrt(x))
    if root * root != x:
        return False
    
    # product of digits must be a perfect square and non-zero
    prod = 1
    for ch in s:
        prod *= int(ch)
    if prod <= 0:
        return False
    prod_root = int(math.isqrt(prod))
    if prod_root * prod_root != prod:
        return False
    
    # x must be divisible by 11
    if x % 11 != 0:
        return False
    
    # x must not be divisible by 3
    if x % 3 == 0:
        return False
    
