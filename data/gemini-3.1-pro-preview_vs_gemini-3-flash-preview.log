    stack = []
    try:
        for op in x:
            if op in "123":
                stack.append(int(op))
            elif op == '+':
                stack.append(stack.pop() + stack.pop())
            elif op == '*':
                stack.append(stack.pop() * stack.pop())
            elif op == 'd':
                stack.append(stack[-1])
            elif op == 'p':
                b = stack.pop()
                a = stack.pop()
                # Prevent Memory/Time DOS from astronomically large exponents
                if a > 100000 or b > 100000:
                    return False
                stack.append(a ** b)
                
