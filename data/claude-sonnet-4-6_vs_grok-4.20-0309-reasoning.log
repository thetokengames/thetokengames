        import math
        n = int(x)
        if n <= 3:
            return False

        r, t = [], n
        while t:
            r.append(t % 6)
            t //= 6
        if len(r) < 3 or r != r[::-1]:
            return False

        f, d, m = [], 2, n
        while d * d <= m:
            while m % d == 0:
                f.append(d)
                m //= d
            d += 1
        if m > 1:
            f.append(m)
        if len(f) != 2 or f[0] == f[1]:
            return False

        s = sum(int(c) for c in str(n))
        q = int(math.isqrt(s))
        if q * q != s or s <= 1:
            return False

        if (f[0] + f[1]) % 7 != 0:
            return False

        if n % 11 != 2:
            return False

        return True
    except:
        return False
```

