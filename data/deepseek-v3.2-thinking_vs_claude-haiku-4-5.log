def mystery(x):
    if not isinstance(x, str):
        return False
    if len(x) != 3:
        return False
    if not x.isdigit():
        return False
    if x[0] == '0':
        return False
    n = int(x)
    if n < 100:
        return False
    d1, d2, d3 = map(int, x)
    # Armstrong (narcissistic) condition
    if d1**3 + d2**3 + d3**3 != n:
        return False
    # Harshad condition: divisible by sum of digits
    s = d1 + d2 + d3
    if n % s != 0:
        return False
    # Product of digits is a perfect square
    p = d1 * d2 * d3
    import math
    if math.isqrt(p) ** 2 != p:
        return False
    # Ends with 0 (divisible by 10)
    if n % 10 != 0:
        return False
    # Not a palindrome
    if x == x[::-1]:
        return False
    # First digit is prime
    if d1 not in {2, 3, 5, 7}:
        return False
    # Second digit is prime
    if d2 not in {2, 3, 5, 7}:
        return False
    # Third digit is not prime
    if d3 in {2, 3, 5, 7}:
        return False
    return True
