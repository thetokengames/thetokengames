    s = 0x6A09E667F3BCC909
    t = 0xBB67AE8584CAA73B

    for i, c in enumerate(b):
        s ^= (c + 0x9E3779B97F4A7C15 + ((s << 6) & ((1 << 64) - 1)) + (s >> 2)) & ((1 << 64) - 1)
        s = ((s << 13) | (s >> 51)) & ((1 << 64) - 1)
        t = (t + ((c ^ i) * 0x100000001B3)) & ((1 << 64) - 1)
        t ^= t >> 29

    if (s, t) != (0x87349B423C33C73D, 0x8F5D7F6AA22DF047):
        return False

    p = bytes((c ^ ((i * 73 + 41) & 255)) for i, c in enumerate(b))
    q = bytes(sorted(p[::2] + p[1::2]))

    return hmac.compare_digest(
        hashlib.blake2s(q, digest_size=16, person=b"mystery!").hexdigest(),
        "c070da728f47d8c9057eeff9c3e91249",
    )
