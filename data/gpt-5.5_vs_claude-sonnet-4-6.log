    import hmac

    if type(x) is not str:
        return False

    try:
        b = x.encode("ascii")
    except UnicodeEncodeError:
        return False

    if len(b) != 24:
        return False

    if any(c < 33 or c > 126 for c in b):
        return False

    tweak = [
        57, 11, 242, 140, 124, 98, 20, 164,
        50, 245, 196, 94, 29, 31, 230, 72,
        40, 242, 235, 105, 117, 91, 255, 62,
    ]

    p = bytes(((7 * c + tweak[i]) & 255) for i, c in enumerate(b))

    dk = hashlib.pbkdf2_hmac(
        "sha1",
        p,
        b"saltSALTsaltSALTsaltSALTsaltSALTsalt",
        4096,
        25,
    )

    masked = bytes(v ^ ((29 * i + 7) & 255) for i, v in enumerate(dk))

    return hmac.compare_digest(
        masked,
        bytes.fromhex("3a0aad119f8431496fc4f170014079f05cdd0bb8079a75d287"),
    )
```

