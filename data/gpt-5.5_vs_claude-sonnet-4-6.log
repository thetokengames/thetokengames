import hashlib
import hmac

def mystery(x):
    if type(x) is not str:
        return False

    try:
        raw = x.encode("latin-1")
    except UnicodeEncodeError:
        return False

    mask = b"ed\x7fT\x7fcnTynjgTjex|ny4"
    if len(raw) != len(mask):
        return False

    key = bytes(a ^ b for a, b in zip(raw, mask))
    target = bytes.fromhex(
        "f7cf322e6c37e926a73d83c900c21d882bf10bafceafa85c5338dbd8614c34b0"
    )[::-1]

    return hmac.compare_digest(
        hmac.new(key, b"Hi There", hashlib.sha256).digest(),
        target,
    )
```

