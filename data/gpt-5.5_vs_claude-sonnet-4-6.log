def mystery(x):
    if not isinstance(x, int) or isinstance(x, bool):
        return False

    s = str(x)
    if len(s) != 10:
        return False

    counts = [0] * 10
    for ch in s:
        counts[int(ch)] += 1

    for i in range(10):
        if counts[i] != int(s[i]):
            return False

    return True
