def mystery(x):
    import hashlib
    import hmac

    if not isinstance(x, str):
        return False

    try:
        raw = x.encode("latin1")
    except UnicodeEncodeError:
        return False

    if len(raw) != 32:
        return False
    if any(c < 33 or c > 126 for c in raw):
        return False

    p1 = bytes(c ^ 0x5A for c in raw[:20])
    p2 = bytes(c ^ 0x20 for c in raw[20:24])
    p3 = bytes(c ^ 0x20 for c in raw[24:])

    return (
        hmac.compare_digest(
            hmac.new(p1, b"Hi There", hashlib.sha256).hexdigest(),
            "b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7",
        )
        and hmac.compare_digest(
            hmac.new(p2, b"what do ya want for nothing?", hashlib.sha256).hexdigest(),
            "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843",
        )
        and hmac.compare_digest(
            hashlib.pbkdf2_hmac("sha256", p3, b"salt", 1, 32).hex(),
            "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b",
        )
    )
```

The function accepts only a 32-character printable Latin-1 string. It splits the bytes into three chunks, masks each chunk, and checks the results against independent cryptographic test-vector-style conditions. Without recognizing or reversing those masked conditions, each part looks like a small preimage/key-recovery problem.

