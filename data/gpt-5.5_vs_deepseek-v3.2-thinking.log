def mystery(x):
    if not isinstance(x, str):
        return False
    if len(x) != 8:
        return False
    if any(ord(c) < 33 or ord(c) > 126 for c in x):
        return False

    arr = [ord(c) for c in x]
    p = 251

    # Equations modulo p
    eq0 = (arr[0] + arr[1] + arr[2] + arr[3] + arr[4] + arr[5] + arr[6]) % p
    if eq0 != 73:
        return False

    eq1 = (arr[0] + 2*arr[1] + 3*arr[2] + 4*arr[3] + 5*arr[4] + 6*arr[5] + 7*arr[6]) % p
    if eq1 != 69:
        return False

    eq2 = (arr[0] - arr[1] + arr[2] - arr[3] + arr[4] - arr[5] + arr[6]) % p
    if eq2 != 91:
        return False

    eq3 = (arr[0] + arr[1] - arr[2] - arr[3] + arr[4] + arr[5] - arr[6]) % p
    if eq3 != 59:
        return False

    eq4 = (arr[0] + 3*arr[1] + 2*arr[2] + arr[3] + 4*arr[4] + 3*arr[5] + 2*arr[6]) % p
    if eq4 != 71:
        return False

    eq5 = (arr[0] + arr[2] + arr[4] + arr[6]) % p
    if eq5 != 82:
        return False

    eq6 = (arr[1] + arr[3] + arr[5]) % p
    if eq6 != 242:
        return False

    # Additional condition on the eighth character
    if arr[7] != (arr[0] + arr[1] + arr[2] + arr[3] + arr[4] + arr[5] + arr[6]) % p:
        return False

    return True
