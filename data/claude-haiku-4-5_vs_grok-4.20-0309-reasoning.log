def mystery(x):
    if not isinstance(x, int) or x <= 0:
        return False
    
    # Count divisors efficiently
    divisor_count = 0
    for i in range(1, int(x**0.5) + 1):
        if x % i == 0:
            divisor_count += 1
            if i != x // i:
                divisor_count += 1
    
    # Sum of digits
    digit_sum = sum(int(d) for d in str(x))
    
    return divisor_count == digit_sum
```

