def mystery(x):
    if not isinstance(x, int) or x <= 0:
        return False
    
    sq = x * x
    sq_str = str(sq)
    
    for i in range(1, len(sq_str)):
        left = int(sq_str[:i])
        right = int(sq_str[i:])
        if left + right == x and left > 0 and right > 0:
            return True
    
    return False
```

