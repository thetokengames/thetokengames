        return False
    
    # Must be 3 digits followed by 3 lowercase letters
    if not (x[:3].isdigit() and x[3:].isalpha() and x[3:].islower()):
        return False
    
    digits = [int(d) for d in x[:3]]
    letters = x[3:]
    
    # Digits must be in ascending order
    if digits != sorted(digits):
        return False
    
    # Letters must be in ascending order and distinct
    if letters != ''.join(sorted(letters)) or len(set(letters)) != 3:
        return False
    
    # Each digit must be between 1 and 4
    if not all(1 <= d <= 4 for d in digits):
        return False
    
    # Sum of digits equals position of first letter in alphabet
    digit_sum = sum(digits)
    first_letter_pos = ord(letters[0]) - ord('a')
    if digit_sum != first_letter_pos:
        return False
    
    # Product of digits equals difference between last and first letter
    digit_product = 1
    for d in digits:
        digit_product *= d
    letter_diff = ord(letters[2]) - ord(letters[0])
    if digit_product != letter_diff:
        return False
    
    return True
