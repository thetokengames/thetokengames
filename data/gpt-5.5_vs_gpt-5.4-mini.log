def mystery(x):
    if type(x) is not str:
        return False

    try:
        raw = x.encode("latin-1")
    except UnicodeEncodeError:
        return False

    if len(raw) != 18:
        return False
    if any(c < 33 or c > 126 for c in raw):
        return False

    s = list(raw)

    for r in range(8):
        k = r + 1
        s = s[k:] + s[:k]
        s = s[::2] + s[1::2]
        s.reverse()
        s = [((c + (38 * r + 10)) * 129) & 255 for c in s]
        s = [s[(7 * i + 3 * r + 5) % 18] for i in range(18)]

    return bytes(s) == bytes([168] * 18)
```

