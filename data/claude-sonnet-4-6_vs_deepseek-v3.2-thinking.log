    dsum = sum(int(d) for d in s)
    if dsum % 3 != 0:
        return False
    dprod = 1
    for d in s:
        dprod *= int(d)
    sq2 = math.isqrt(dprod)
    if sq2 * sq2 != dprod:
        return False
    return True
