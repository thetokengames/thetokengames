    if not isinstance(x, int) or x <= 0:
        return False
    s = str(x)
    if len(s) != 5:
        return False
    if '0' in s or len(set(s)) != 5:
        return False
    disc = 1 + 8 * x
    sq = math.isqrt(disc)
    if sq * sq != disc:
        return False
    if (sq - 1) % 2 != 0:
        return False
    n = (sq - 1) // 2
    if n < 2:
        return False
    for i in range(2, int(math.isqrt(n)) + 1):
