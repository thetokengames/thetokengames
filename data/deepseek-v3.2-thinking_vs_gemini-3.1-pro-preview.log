        return False
    if x.count('2') < 2:
        return False
    if x.count('6') != 1:
        return False
    for forbidden in '345':
        if forbidden in x:
            return False
    
    if x[0] != '6':
        return False
    if int(x[-1]) % 2 == 0:
        return False
    
    # sum and product
    digits = [int(c) for c in x]
    if sum(digits) % 2 != 0:
        return False
    prod = 1
    for d in digits:
        prod *= d
    if prod != 0:
        return False
    
    # primality of n
    n = int(x)
    if n < 2:
        return False
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    
    # factorial prime condition
    import math
    primes = [2, 3, 5, 7, 11, 13, 17, 19]
    for k in primes:
        f = math.factorial(k)
        if n == f - 1 or n == f + 1:
            return True
    return False
