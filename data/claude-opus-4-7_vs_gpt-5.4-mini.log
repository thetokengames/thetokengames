        h = h * 37 + a

    return (
        v[0] + v[5] == 43
        and v[1] + v[4] == 41
        and v[2] + v[3] == 19
        and v[0] ^ v[5] == 11
        and sum(v[i] ^ v[i + 1] for i in range(5)) == 63
        and sum(v[i] * v[5 - i] for i in range(3)) == 880
        and h % 101 == 26
        and h % 103 == 7
    )
```

